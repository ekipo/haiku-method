{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_PLUGIN_ROOT": "plugin"
  },
  "enabledPlugins": {
    "core@han": true,
    "bushido@han": true,
    "haiku@haiku-dev": true
  },
  "extraKnownMarketplaces": {
    "haiku-dev": {
      "source": {
        "source": "directory",
        "path": "./dev"
      },
      "autoUpdate": true
    },
    "han": {
      "source": {
        "source": "github",
        "repo": "thebushidocollective/han"
      }
    }
  },
  "teammateMode": "tmux"
}
