#!/usr/bin/env bash
# No-op. The primary worktree is no longer pinned to the default branch.
#
# Branch protection now lives in pre-commit (which blocks commits on the
# default branch regardless of worktree). Checkouts are unrestricted, so
# the primary worktree can sit on any feature branch — useful when the
# MCP runtime or another tool needs the primary's working tree to match
# a specific branch's state (e.g. drift baseline + dev/plugin symlink
# living on a feature branch).
#
# Kept as a present-but-empty hook file so future logic can be slotted
# in without re-arguing the existence of the file.

exit 0
