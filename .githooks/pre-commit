#!/usr/bin/env bash
# Block commits on the default branch. Branch work — including commits —
# must land on a non-default branch. No bypass.

set -e

# Resolve default branch from origin/HEAD; fall back to main.
default_branch=$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's@^origin/@@' || true)
default_branch=${default_branch:-main}

# Detached HEAD returns empty — allow it; nothing to protect.
current_branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)
[ -z "$current_branch" ] && exit 0

[ "$current_branch" = "$default_branch" ] || exit 0

cat >&2 <<EOF

✋ blocked: commits are not allowed on '$default_branch'

   the default branch is protected — switch to a feature branch:

       git switch -c <branch>                      # new branch off HEAD
       git worktree add -b <branch> ../<dir>       # new branch in linked worktree

EOF

exit 1
