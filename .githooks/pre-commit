#!/usr/bin/env bash
# Block commits in the primary worktree. All work must happen in a linked
# worktree (`git worktree add ...`). No bypass.

set -e

# Skip linked worktrees — only enforce in the primary.
git_dir=$(git rev-parse --git-dir)
common_dir=$(git rev-parse --git-common-dir)
abs_git_dir=$(cd "$git_dir" && pwd)
abs_common_dir=$(cd "$common_dir" && pwd)
[ "$abs_git_dir" = "$abs_common_dir" ] || exit 0

cat >&2 <<EOF

✋ blocked: commits are not allowed in the primary worktree

   primary is pinned to the default branch (post-checkout hook); branch
   work — including commits — must happen in a linked worktree:

       git worktree add .claude/worktrees/<dir> <branch>          # existing branch
       git worktree add -b <branch> .claude/worktrees/<dir>       # new branch off HEAD

EOF

exit 1
