{
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"packages/**",
			"website/**",
			"deploy/**",
			"!**/dist/*",
			"!**/bin/*",
			"!.haiku/**/*",
			"!.claude/**/*",
			"!**/__generated__",
			"!**/node_modules",
			"!**/dist",
			"!**/.next",
			"!**/build",
			"!website/public",
			"!website/schema/github.graphql",
			"!website/schema/gitlab.graphql"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "asNeeded"
		}
	},
	"css": {
		"parser": {
			"cssModules": true,
			"tailwindDirectives": true
		}
	}
}
