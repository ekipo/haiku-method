{
	"name": "haiku-api",
	"version": "0.1.0",
	"type": "module",
	"private": true,
	"description": "Zod + OpenAPI contract shared by the H·AI·K·U MCP backend and agent-collab UI.",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./openapi.json": "./dist/openapi.json"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsc && node scripts/emit-openapi.mjs",
		"typecheck": "tsc --noEmit",
		"test": "node test/run-all.mjs",
		"audit:openapi-parity": "node scripts/audit-openapi-parity.mjs"
	},
	"dependencies": {
		"zod": "^3.23.0",
		"zod-to-json-schema": "^3.23.5"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"tsx": "^4.21.0",
		"typescript": "^5.7.0"
	}
}
