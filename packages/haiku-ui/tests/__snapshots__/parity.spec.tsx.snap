rflow-y-auto" id="main-content" role="main" aria-label="Design Direction content" tabindex="-1"><div class="max-w-[var(--content-max)] mx-auto px-4 sm:px-6 lg:px-8 py-6 space-y-4"><form novalidate=""><div class="bg-white dark:bg-stone-900 rounded-xl border border-stone-200 dark:border-stone-700 shadow-sm p-6 mb-6 "><fieldset class="border-0 p-0 m-0"><legend class="text-sm font-medium text-stone-900 dark:text-stone-100 mb-2">What do you want to do?</legend><div class="flex flex-wrap gap-2"><label for="direction-mode-select" class="flex items-center gap-2 px-3 py-2 rounded-lg border cursor-pointer transition-colors touch-target border-teal-600 dark:border-teal-400 bg-teal-50 dark:bg-teal-900/20"><input id="direction-mode-select" aria-checked="true" class="w-4 h-4 text-teal-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal-500 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-stone-900" type="radio" value="select" checked="" name="direction-mode"><span class="text-sm text-stone-900 dark:text-stone-100">Pick one of these</span></label><label for="direction-mode-regenerate" class="flex items-center gap-2 px-3 py-2 rounded-lg border cursor-pointer transition-colors touch-target border-stone-200 dark:border-stone-700 hover:border-stone-400 dark:hover:border-stone-500"><input id="direction-mode-regenerate" aria-checked="false" class="w-4 h-4 text-teal-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal-500 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-stone-900" type="radio" value="regenerate" name="direction-mode"><span class="text-sm text-stone-900 dark:text-stone-100">Show me different variants</span></label></div></fieldset></div><div class="bg-white dark:bg-stone-900 rounded-xl border border-stone-200 dark:border-stone-700 shadow-sm p-6 mb-6 "><fieldset role="radiogroup" aria-labelledby="direction-prompt-title" class="border-0 p-0 m-0"><legend id="direction-prompt-title" class="text-lg font-semibold mb-3 text-stone-900 dark:text-stone-100">Pick a design direction</legend><p class="text-sm text-stone-600 dark:text-stone-300 mb-4">Select an archetype, drop pins on its preview, then submit.</p><div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3"><div class="relative"><label for="direction-radio-minimal" class="group relative block w-full cursor-pointer rounded-xl border-2 p-4 text-left transition-colors border-teal-600 dark:border-teal-400 bg-teal-50 dark:bg-teal-900/20"><div class="flex items-center gap-2 mb-2"><input id="direction-radio-minimal" aria-checked="true" class="w-4 h-4 text-teal-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal-500 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-stone-900" type="radio" value="Minimal" checked="" name="direction"><span class="font-semibold text-stone-900 dark:text-stone-100">Minimal</span></div><p class="text-sm text-stone-600 dark:text-stone-300 mb-3">Spare layout, plenty of whitespace, focus on typography.</p><iframe srcdoc="<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 200 120'><rect width='200' height='120' fill='#fafaf9'/><rect x='20' y='20' width='80' height='10' fill='#1c1917'/><rect x='20' y='40' width='160' height='4' fill='#a8a29e'/><rect x='20' y='52' width='160' height='4' fill='#a8a29e'/></svg>" sandbox="" title="Preview: Minimal" aria-label="Preview: Minimal" class="w-full h-40 rounded-lg border border-stone-200 dark:border-stone-700 bg-white pointer-events-none"></iframe></label><button type="button" aria-label="View full size preview: Minimal" class="mt-2 text-xs text-teal-700 dark:text-teal-300 underline underline-offset-2 rounded-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal-500 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-stone-900">View full size</button></div><div class="relative"><label for="direction-radio-bold" class="group relative block w-full cursor-pointer rounded-xl border-2 p-4 text-left transition-colors border-stone-200 dark:border-stone-700 hover:border-stone-400 dark:hover:border-stone-500"><div class="flex items-center gap-2 mb-2"><input id="direction-radio-bold" aria-checked="false" class="w-4 h-4 text-teal-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal-500 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-stone-900" type="radio" value="Bold" name="direction"><span class="font-semibold text-stone-900 dark:text-stone-100">Bold</span></div><p class="text-sm text-stone-600 dark:text-stone-300 mb-3">Heavy type, saturated accent, generous padding.</p><iframe srcdoc="<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 200 120'><rect width='200' height='120' fill='#0c0a09'/><rect x='20' y='20' width='120' height='18' fill='#14b8a6'/><rect x='20' y='48' width='160' height='4' fill='#e7e5e4'/><rect x='20' y='60' width='160' height='4' fill='#e7e5e4'/></svg>" sandbox="" title="Preview: Bold" aria-label="Preview: Bold" class="w-full h-40 rounded-lg border border-stone-200 dark:border-stone-700 bg-white pointer-events-none"></iframe></label><button type="button" aria-label="View full size preview: Bold" class="mt-2 text-xs text-teal-700 dark:text-teal-300 underline underline-offset-2 rounded-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal-500 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-stone-900">View full size</button></div><div class="relative"><label for="direction-radio-playful" class="group relative block w-full cursor-pointer rounded-xl border-2 p-4 text-left transition-colors border-stone-200 dark:border-stone-700 hover:border-stone-400 dark:hover:border-stone-500"><div class="flex items-center gap-2 mb-2"><input id="direction-radio-playful" aria-checked="false" class="w-4 h-4 text-teal-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal-500 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-stone-900" type="radio" value="Playful" name="direction"><span class="font-semibold text-stone-900 dark:text-stone-100">Playful</span></div><p class="text-sm text-stone-600 dark:text-stone-300 mb-3">Rounded shapes, soft shadows, cheerful accent colors.</p><iframe srcdoc="<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 200 120'><rect width='200' height='120' fill='#fef3c7'/><circle cx='45' cy='55' r='20' fill='#f97316'/><rect x='80' y='40' width='100' height='8' rx='4' fill='#78350f'/><rect x='80' y='56' width='100' height='8' rx='4' fill='#78350f'/></svg>" sandbox="" title="Preview: Playful" aria-label="Preview: Playful" class="w-full h-40 rounded-lg border border-stone-200 dark:border-stone-700 bg-white pointer-events-none"></iframe></label><button type="button" aria-label="View full size preview: Playful" class="mt-2 text-xs text-teal-700 dark:text-teal-300 underline underline-offset-2 rounded-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal-500 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-stone-900">View full size</button></div></div></fieldset></div><div class="bg-white dark:bg-stone-900 rounded-xl border border-stone-200 dark:border-stone-700 shadow-sm p-6 mb-6 "><h2 class="text-lg font-semibold mb-3 text-stone-900 dark:text-stone-100">Minimal preview</h2><p class="text-sm text-stone-600 dark:text-stone-300 mb-3">The preview is interactive by default. Click the pencil FAB (bottom-right) to enter annotation mode, draw on the surface, and add a comment. Each annotation pass is screenshotted via the browser's screen-share permission so the agent sees what you saw — same pattern as the review UI.</p><div class="space-y-3"><div class="relative rounded-md overflow-hidden border border-stone-200 dark:border-stone-800 bg-white"><iframe srcdoc="<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 200 120'><rect width='200' height='120' fill='#fafaf9'/><rect x='20' y='20' width='80' height='10' fill='#1c1917'/><rect x='20' y='40' width='160' height='4' fill='#a8a29e'/><rect x='20' y='52' width='160' height='4' fill='#a8a29e'/></svg>" sandbox="allow-scripts allow-same-origin" title="Preview: Minimal" aria-label="Preview: Minimal" class="w-full h-[60vh] border-0 bg-white"></iframe><svg class="absolute inset-0 w-full h-full pointer-events-none" aria-hidden="true"><title>Annotation overlay</title></svg></div><button type="button" aria-pressed="false" aria-label="Enter annotation mode" class="fixed bottom-4 right-4 z-40 inline-flex items-center justify-center rounded-full shadow-lg w-12 h-12 border transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal-500 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-stone-900 bg-white dark:bg-stone-900 border-stone-300 dark:border-stone-600 text-stone-700 dark:text-stone-200 hover:bg-stone-100 dark:hover:bg-stone-800"><svg aria-hidden="true" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 1 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg></button></div></div><div class="bg-white dark:bg-stone-900 rounded-xl border border-stone-200 dark:border-stone-700 shadow-sm p-6 mb-6 "><label for="direction-comment" class="block text-sm font-medium text-stone-900 dark:text-stone-100 mb-2">Optional comment</label><textarea id="direction-comment" class="w-full p-3 border border-stone-300 dark:border-stone-600 rounded-lg bg-white dark:bg-stone-800 text-stone-900 dark:text-stone-100 resize-y text-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal-500 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-stone-900" rows="3" placeholder="Anything else worth noting about this direction..."></textarea></div><button type="submit" aria-disabled="false" class="w-full px-6 py-3 bg-teal-700 hover:bg-teal-800 text-white font-semibold rounded-lg transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal-500 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-stone-900 disabled:bg-green-300 disabled:text-green-800 dark:disabled:bg-green-900/40 dark:disabled:text-green-200 disabled:cursor-not-allowed touch-target">Choose This Direction</button></form></div></main></div><div id="feedback-live-polite" role="status" aria-live="polite" aria-atomic="true" class="sr-only"></div><div id="feedback-live-assertive" role="alert" aria-live="assertive" aria-atomic="true" class="sr-only"></div>"`;

